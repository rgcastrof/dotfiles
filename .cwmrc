fontname "IosevkaTerm Nerd Font:pixelsize=16"
sticky yes
borderwidth 2
snapdist 10

color activeborder "#80a0ff"
color inactiveborder "#323437"
color font "#eeeeee"
color selfont "#323437"
color menubg "#080808"
color menufg "#80a0ff"

unbind-key all

bind-key 4S-q quit
bind-key 4S-r restart

bind-key 4-Return terminal

bind-key 4-p menu-exec
bind-key 4-w menu-window

bind-key 4-1 group-only-1
bind-key 4-2 group-only-2
bind-key 4-3 group-only-3
bind-key 4-4 group-only-4
bind-key 4-5 group-only-5
bind-key 4-6 group-only-6
bind-key 4-7 group-only-7
bind-key 4-8 group-only-8
bind-key 4-9 group-only-9

bind-key 4S-1 window-movetogroup-1
bind-key 4S-2 window-movetogroup-2
bind-key 4S-3 window-movetogroup-3
bind-key 4S-4 window-movetogroup-4
bind-key 4S-5 window-movetogroup-5
bind-key 4S-6 window-movetogroup-6
bind-key 4S-7 window-movetogroup-7
bind-key 4S-8 window-movetogroup-8
bind-key 4S-9 window-movetogroup-9

bind-key 4-0 group-toggle-all

bind-key 4-q window-delete
bind-key 4-g window-group
bind-key 4-BackSpace window-hide
bind-key 4-s window-stick
bind-key 4-r window-menu-label
bind-key 4-j window-cycle
bind-key 4-k window-rcycle
bind-key 4-v window-vtile
bind-key 4-i window-htile
bind-key 4-f window-fullscreen
bind-key 4-m window-maximize

vtile 55

bind-mouse 4-1 window-move
bind-mouse 4S-1 window-resize

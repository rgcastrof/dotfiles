syntax on
filetype plugin indent on
set number
set relativenumber
set smartindent
set noswapfile
set nowrap
set termguicolors
set cursorline
set signcolumn=yes
set colorcolumn=80
set tabstop=4
set shiftwidth=4
set backspace=indent,eol,start
set background=dark
set backupdir=/tmp//
set directory=/tmp//
set undodir=/tmp//

colorscheme moonfly
